  int j = 0;
  for (int i = 0; i < res; ++i) {
    if (strcmp(".", namelist[i]->d_name) != 0 
          && strcmp("..", namelist[i]->d_name) != 0) {
      assert(!strcmp(golden[j], namelist[i]->d_name));
      ++j;
    }
    free(namelist[i]);
  }
  free(namelist);
}
